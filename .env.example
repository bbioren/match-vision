# Optional. App falls back safely without these.

# LLM provider for ADC + Q&A generation: qwen | anthropic | fallback
# Leave blank to auto-detect (Qwen if DASHSCOPE_API_KEY is set, else Anthropic, else local fallback).
LLM_PROVIDER=

# Qwen via Alibaba Cloud Model Studio (DashScope), OpenAI-compatible endpoint.
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-flash
QWEN_VL_MODEL=qwen3-vl-plus
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Anthropic (alternative generator).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Deepgram for real TTS (browser TTS used otherwise).
DEEPGRAM_API_KEY=

PORT=5173
