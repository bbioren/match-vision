{
  "manifest_version": 3,
  "name": "MatchVision Eye Tracker",
  "version": "1.8.0",
  "description": "Gaze-controlled zoom & pan for any web video. Accessibility tool for low-vision users.",

  "permissions": ["activeTab", "tabs", "storage", "scripting", "debugger"],
  "host_permissions": ["<all_urls>"],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src https:"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["secrets.js", "tracker.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "MatchVision Eye Tracker"
  },

  "web_accessible_resources": [
    {
      "resources": ["models/*", "tracker-window.html", "tracker-window.js",
                    "raf-override.js", "model-interceptor.js", "webgazer.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
